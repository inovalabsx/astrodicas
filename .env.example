# AstroDicas — Config

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# LLM
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Banco
DATABASE_URL=postgresql://astrodicas:astrodicas@postgres:5432/astrodicas
REDIS_URL=redis://redis:6379/0

# Pagamento
ASAAS_API_KEY=
ASAAS_ENV=sandbox
STRIPE_API_KEY=
STRIPE_PIX_ENABLED=true

# Crypto
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
CRYPTO_SWAP_ENABLED=true

# Instagram
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=

# Imagem
IMAGE_API_KEY=           # DALL-E / Stability
IMAGE_MODEL=dall-e-3
IMAGE_STYLE=astrodicas   # Nome do preset de identidade visual

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Scheduler
POST_MORNING=06:00
POST_AFTERNOON=12:00
POST_NIGHT=18:00
TIMEZONE=America/Sao_Paulo
